# Database Configuration for Runtime Validation
# Copy this file to db-config.properties and fill in your credentials
# WARNING: Never commit db-config.properties with real credentials!

# ============================================
# DB2 Configuration
# ============================================
db2.enabled=false
db2.url=jdbc:db2://localhost:50000/MAXDB76
db2.username=your_db2_username
db2.password=your_db2_password
db2.driver=com.ibm.db2.jcc.DB2Driver

# ============================================
# PostgreSQL Configuration
# ============================================
postgres.enabled=false
postgres.url=jdbc:postgresql://localhost:5432/maxdb76
postgres.username=your_postgres_username
postgres.password=your_postgres_password
postgres.driver=org.postgresql.Driver

# ============================================
# Oracle Configuration
# ============================================
oracle.enabled=false
oracle.url=jdbc:oracle:thin:@localhost:1521:ORCL
oracle.username=your_oracle_username
oracle.password=your_oracle_password
oracle.driver=oracle.jdbc.driver.OracleDriver

# ============================================
# Runtime Validation Settings
# ============================================
# Only SELECT queries will be executed for safety
runtime.validation.enabled=false
runtime.validation.timeout=30000
runtime.validation.max.rows=1000

# ============================================
# Notes:
# ============================================
# 1. Set enabled=true for databases you want to test
# 2. Ensure JDBC drivers are in the lib/ directory:
#    - db2jcc4.jar for DB2
#    - postgresql-42.x.x.jar for PostgreSQL
#    - ojdbc8.jar for Oracle
# 3. Only SELECT queries are executed for safety
# 4. Results are compared across all enabled databases